{
  "pipeline": {
    "name": "AI Sales Pipeline",
    "display_order": 0,
    "stages": [
      {
        "label": "Lead Captured",
        "display_order": 0,
        "probability": 0.10,
        "metadata": {
          "trigger": "Auto-created when lead enters Clay with score >= 7",
          "actions": ["Create contact", "Create deal", "Log source"]
        }
      },
      {
        "label": "Contacted",
        "display_order": 1,
        "probability": 0.20,
        "metadata": {
          "trigger": "Lead added to Instantly campaign",
          "actions": ["Update deal stage", "Log campaign name"]
        }
      },
      {
        "label": "Replied — Interested",
        "display_order": 2,
        "probability": 0.40,
        "metadata": {
          "trigger": "GPT classifies reply as INTERESTED",
          "actions": ["Update deal stage", "Add reply as note", "Generate lead brief", "Send meeting request"]
        }
      },
      {
        "label": "Meeting Scheduled",
        "display_order": 3,
        "probability": 0.60,
        "metadata": {
          "trigger": "Google Calendar event created with prospect",
          "actions": ["Update deal stage", "Log meeting details", "Notify owner"]
        }
      },
      {
        "label": "Meeting Completed",
        "display_order": 4,
        "probability": 0.70,
        "metadata": {
          "trigger": "Manual — after meeting ends",
          "actions": ["Update deal stage", "Add meeting notes"]
        }
      },
      {
        "label": "Proposal Sent",
        "display_order": 5,
        "probability": 0.80,
        "metadata": {
          "trigger": "Manual — you send the proposal",
          "actions": ["Update deal stage", "Log proposal details"]
        }
      },
      {
        "label": "Payment Link Sent",
        "display_order": 6,
        "probability": 0.90,
        "metadata": {
          "trigger": "Workflow 06 — Razorpay link generated and sent",
          "actions": ["Update deal stage", "Store payment link URL"]
        }
      },
      {
        "label": "Closed Won",
        "display_order": 7,
        "probability": 1.00,
        "metadata": {
          "trigger": "Razorpay webhook — payment.captured",
          "actions": ["Update deal stage", "Send onboarding email", "Schedule kickoff"]
        }
      },
      {
        "label": "Closed Lost",
        "display_order": 8,
        "probability": 0.00,
        "metadata": {
          "trigger": "GPT classifies reply as NOT_INTERESTED or manual",
          "actions": ["Update deal stage", "Archive contact"]
        }
      }
    ]
  },
  "custom_properties": {
    "contact_properties": [
      {
        "name": "ai_relevance_score",
        "label": "AI Relevance Score",
        "type": "number",
        "description": "Lead relevance score (1-10) generated by GPT via Clay enrichment",
        "group_name": "ai_sales_data"
      },
      {
        "name": "ai_pain_point",
        "label": "AI Pain Point",
        "type": "string",
        "description": "Hypothesized pain point generated by GPT",
        "group_name": "ai_sales_data"
      },
      {
        "name": "ai_personalized_note",
        "label": "AI Personalized Note",
        "type": "string",
        "description": "Personalized observation about the prospect's company",
        "group_name": "ai_sales_data"
      },
      {
        "name": "outreach_campaign",
        "label": "Outreach Campaign",
        "type": "string",
        "description": "Name of the Instantly campaign this contact was added to",
        "group_name": "ai_sales_data"
      },
      {
        "name": "lead_source",
        "label": "Lead Source",
        "type": "enumeration",
        "description": "Where this lead originated",
        "options": [
          {"label": "Apollo", "value": "apollo"},
          {"label": "Inbound", "value": "inbound"},
          {"label": "Referral", "value": "referral"},
          {"label": "LinkedIn", "value": "linkedin"},
          {"label": "Manual", "value": "manual"}
        ],
        "group_name": "ai_sales_data"
      },
      {
        "name": "reply_classification",
        "label": "Reply Classification",
        "type": "enumeration",
        "description": "GPT classification of the prospect's reply",
        "options": [
          {"label": "Interested", "value": "interested"},
          {"label": "Not Interested", "value": "not_interested"},
          {"label": "Objection", "value": "objection"},
          {"label": "Referral", "value": "referral"},
          {"label": "Out of Office", "value": "out_of_office"},
          {"label": "No Reply", "value": "no_reply"}
        ],
        "group_name": "ai_sales_data"
      }
    ],
    "deal_properties": [
      {
        "name": "payment_link_url",
        "label": "Razorpay Payment Link",
        "type": "string",
        "description": "URL of the Razorpay payment link sent to the client",
        "group_name": "ai_sales_data"
      },
      {
        "name": "payment_status",
        "label": "Payment Status",
        "type": "enumeration",
        "description": "Current status of the payment",
        "options": [
          {"label": "Not Sent", "value": "not_sent"},
          {"label": "Link Sent", "value": "link_sent"},
          {"label": "Paid", "value": "paid"},
          {"label": "Failed", "value": "failed"}
        ],
        "group_name": "ai_sales_data"
      },
      {
        "name": "service_offered",
        "label": "Service Offered",
        "type": "string",
        "description": "Which service was recommended/offered to this prospect",
        "group_name": "ai_sales_data"
      },
      {
        "name": "razorpay_payment_id",
        "label": "Razorpay Payment ID",
        "type": "string",
        "description": "Razorpay transaction ID after payment is captured",
        "group_name": "ai_sales_data"
      }
    ]
  },
  "property_group": {
    "name": "ai_sales_data",
    "label": "AI Sales Data",
    "display_order": 0
  },
  "api_setup_instructions": {
    "create_private_app": {
      "steps": [
        "Go to HubSpot → Settings → Integrations → Private Apps",
        "Click 'Create a private app'",
        "Name: 'AI Sales Automation'",
        "Under Scopes, enable:",
        "  - crm.objects.contacts.read",
        "  - crm.objects.contacts.write",
        "  - crm.objects.deals.read",
        "  - crm.objects.deals.write",
        "  - crm.objects.companies.read",
        "  - crm.objects.companies.write",
        "  - crm.schemas.contacts.read",
        "  - crm.schemas.deals.read",
        "  - timeline",
        "Click 'Create app' and copy the Access Token"
      ]
    }
  }
}
